{
  "multipart": [
    {
      "apply": {
        "model": "crptapwater:block/pipe_center"
      }
    },
    {
      "when": { "north": true },
      "apply": {
        "model": "crptapwater:block/pipe_side"
      }
    },
    {
      "when": { "south": true },
      "apply": {
        "model": "crptapwater:block/pipe_side",
        "y": 180
      }
    },
    {
      "when": { "east": true },
      "apply": {
        "model": "crptapwater:block/pipe_side",
        "y": 90
      }
    },
    {
      "when": { "west": true },
      "apply": {
        "model": "crptapwater:block/pipe_side",
        "y": 270
      }
    },
    {
      "when": { "up": true },
      "apply": {
        "model": "crptapwater:block/pipe_side",
        "x": 270
      }
    },
    {
      "when": { "down": true },
      "apply": {
        "model": "crptapwater:block/pipe_side",
        "x": 90
      }
    }
  ]
}
